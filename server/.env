# LLM Chat Service — Local Configuration
# Copy to .env and customize

HOST=0.0.0.0
PORT=8008
LOG_LEVEL=INFO
ALLOWED_ORIGINS=*

# Point to your vLLM server (running on port 8007)
VLLM_BASE_URL=http://localhost:8007/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# Existing Voice Gateway
TTS_ENGINE_URL=http://185.14.252.20:8000
STT_ENGINE_URL=http://185.14.252.20:8002
