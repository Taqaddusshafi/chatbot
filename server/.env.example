# ──────────────────────────────────────────────────────────────────────────────
# LLM Chat Service — Configuration
# ──────────────────────────────────────────────────────────────────────────────

# Application
HOST=0.0.0.0
PORT=8008
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# ──────────────────────────────────────────────────────────────────────────────
# vLLM / LLM Backend
# ──────────────────────────────────────────────────────────────────────────────
# Point this to wherever vLLM is serving LLaMA 3.1
VLLM_BASE_URL=http://localhost:8007/v1
VLLM_API_KEY=EMPTY
VLLM_MODEL=meta-llama/Llama-3.1-8B-Instruct
VLLM_TIMEOUT=120.0

# Generation defaults
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=2048
DEFAULT_TOP_P=0.9

# ──────────────────────────────────────────────────────────────────────────────
# Voice Gateway — Existing TTS/STT engines (reused, not duplicated)
# ──────────────────────────────────────────────────────────────────────────────
TTS_ENGINE_URL=http://185.14.252.20:8000
TTS_ENGINE_PATH=/v1/tts
STT_ENGINE_URL=http://185.14.252.20:8002
STT_ENGINE_PATH=/v1/stt
ENGINE_TIMEOUT=60.0
